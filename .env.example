# Environment Variables Template
# Copy this file to .env for local development

# ==========================================
# VITE ENVIRONMENT VARIABLES
# ==========================================
# Note: Vite requires prefix VITE_ untuk expose variables ke client
# Example: VITE_API_URL will be available as import.meta.env.VITE_API_URL

# API Configuration (if needed in future)
# VITE_API_URL=http://localhost:3000
# VITE_API_KEY=your_api_key_here

# Public URLs
# VITE_PUBLIC_URL=/

# Contact Form Configuration (if using external service)
# VITE_FORM_ENDPOINT=your_form_service_endpoint
# VITE_EMAIL_SERVICE_ID=your_email_service_id

# Analytics (optional)
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
# VITE_GTM_ID=GTM-XXXXXXX

# Feature Flags (optional)
# VITE_ENABLE_ANIMATIONS=true
# VITE_ENABLE_CONTACT_FORM=true

# Social Media Links (alternative: bisa juga hardcode di data files)
# VITE_FACEBOOK_URL=https://facebook.com/yourpage
# VITE_INSTAGRAM_URL=https://instagram.com/yourpage
# VITE_LINKEDIN_URL=https://linkedin.com/company/yourcompany

# ==========================================
# NOTES
# ==========================================
# 1. Never commit .env file ke repository!
# 2. .env file is already in .gitignore
# 3. For production, set environment variables di hosting platform
#    - Vercel: Project Settings > Environment Variables
#    - Netlify: Site Settings > Environment Variables
# 4. Only use environment variables untuk sensitive data atau
#    configuration yang berbeda per environment
# 5. Untuk static data seperti company info, lebih baik di data files

# ==========================================
# USAGE IN CODE
# ==========================================
# Access environment variables dengan:
# const apiUrl = import.meta.env.VITE_API_URL;
# const isDev = import.meta.env.DEV;
# const isProd = import.meta.env.PROD;

# ==========================================
# UNTUK ASSIGNMENT INI
# ==========================================
# Kemungkinan besar kamu TIDAK PERLU environment variables
# untuk assignment ini karena:
# - Static website (no backend/API calls)
# - Company info bisa di data files
# - No sensitive data
#
# File ini provided untuk reference saja jika kamu
# ingin extend project dengan features yang butuh env vars.
